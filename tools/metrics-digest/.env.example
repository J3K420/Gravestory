# Copy this file to `.env` (same folder) and fill in the service-role key.
# `.env` is gitignored — the key MUST NOT be committed.
#
# Find the key: Supabase dashboard → your project → Project Settings → API →
# "service_role" secret (NOT the anon key). It bypasses RLS, which is exactly
# why it can read analytics_events / scan_events / scan_credits (those tables
# have no SELECT policy) — and exactly why it can never live in the repo.

SUPABASE_SERVICE_ROLE_KEY=paste-the-service-role-key-here

# Optional — defaults to the GraveStory project URL, override only if it changes.
# SUPABASE_URL=https://idbrjonofqrsykqsqpwo.supabase.co
