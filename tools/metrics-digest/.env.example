# Copy this file to `.env` (same folder) and fill in the service-role key.
# `.env` is gitignored — the key MUST NOT be committed.
#
# Find the key: Supabase dashboard → your project → Project Settings → API →
# "service_role" secret (NOT the anon key). It bypasses RLS, which is exactly
# why it can read analytics_events / scan_events / scan_credits (those tables
# have no SELECT policy) — and exactly why it can never live in the repo.

# Local and production deliberately use different variable names so a target
# cannot silently consume the other environment's privileged credential.
SUPABASE_LOCAL_SERVICE_ROLE_KEY=paste-the-local-service-role-key-here
# SUPABASE_LOCAL_URL=http://127.0.0.1:54321

# Required for --target production. There is deliberately no production default.
# Leave commented for --target local to use http://127.0.0.1:54321.
# The production origin is also checked against the reviewed non-secret allowlist
# in tools/supabase-target-policy.mjs; this explicit value is still required and is never a default.
# SUPABASE_PRODUCTION_URL=https://idbrjonofqrsykqsqpwo.supabase.co
# SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=paste-the-production-service-role-key-here
